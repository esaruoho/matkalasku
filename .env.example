# ─────────────────────────────────────────────────────────────────────────────
# matkalasku — your details. Copy this to `.env` (or just run matkalasku.py once
# and it creates `.env` for you). `.env` is gitignored: it is never shared.
# ─────────────────────────────────────────────────────────────────────────────

# Your full name, as the payee on the claim
NAME=Matti Meikäläinen

# A short handle used in the output filename (e.g. mmeikalainen)
HANDLE=mmeikalainen

# Your bank account number in IBAN format
IBAN=FI00 0000 0000 0000 00

# Your car registration / license plate
CAR_REG=ABC-123

# Where you travel FROM — your home city or district
HOME_CITY=Helsinki

# Path to your signature image (PNG). White background is fine — it is made
# transparent automatically if Pillow is installed. Leave blank for no signature.
SIGNATURE_PATH=signature.png
